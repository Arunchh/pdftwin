# File limits
FREE_FILE_LIMIT_MB=24
PRO_FILE_LIMIT_MB=200

# Auth & billing providers (frontend — set in frontend/.env or Vercel)
# mock = local preview with localStorage; supabase = live Supabase auth
VITE_AUTH_PROVIDER=supabase
VITE_BILLING_PROVIDER=mock

# Supabase (PDF Twin project — frontend/.env)
VITE_SUPABASE_URL=https://tcwvrdykeojriwsxglbn.supabase.co
VITE_SUPABASE_ANON_KEY=

# PayPal payments (https://developer.paypal.com/dashboard/)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Optional — reuse an existing billing plan instead of auto-creating one
PAYPAL_PLAN_ID=
