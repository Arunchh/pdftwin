---
import SiteHeader from "../components/layout/SiteHeader";
import SiteFooter from "../components/layout/SiteFooter";
import CheckoutHost from "../components/CheckoutHost";
import SeoStructuredData from "../components/SeoStructuredData";
import VercelAnalytics from "../components/VercelAnalytics";
import "../index.css";

interface Props {
  title?: string;
  description?: string;
  activeToolLabel?: string;
}

const {
  title = "PDFTwin — Business File Conversion | PDF, Word, Excel & WebP",
  description = "PDFTwin is the one-stop file conversion workspace for businesses. Convert PDFs, images, merge documents, compare revisions, and protect files in your browser.",
  activeToolLabel,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, "https://pdftwin.com/").href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="PDFTwin" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#3b5bdb" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="PDFTwin" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://pdftwin.com/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://pdftwin.com/og-image.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Noto+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Noto+Sans+Arabic:wght@400;500;600;700&family=Noto+Sans+Devanagari:wght@400;500;600;700&family=Noto+Sans+Greek:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        var hash = window.location.hash.replace(/^#/, "").split("?")[0].toLowerCase();
        if (!hash) return;
        var map = {
          convert: "/tools/convert",
          images: "/tools/images",
          compare: "/tools/compare",
          merge: "/tools/merge",
          split: "/tools/split",
          extract: "/tools/extract",
          protect: "/tools/protect",
          pricing: "/pricing",
          tools: "/",
          formats: "/formats",
          faq: "/pricing#faq",
        };
        var target = map[hash];
        if (target) {
          window.location.replace(target + (window.location.hash.includes("?") ? "?" + window.location.hash.split("?")[1] : ""));
        }
      })();
    </script>
  </head>
  <body>
    <div class="site">
      <SeoStructuredData client:load />
      <SiteHeader client:load activeToolLabel={activeToolLabel} />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter client:load />
      <CheckoutHost client:load />
      <VercelAnalytics client:load />
    </div>
  </body>
</html>
