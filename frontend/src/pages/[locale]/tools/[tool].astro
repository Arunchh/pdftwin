---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolWorkspace from "../../../components/ToolWorkspace";
import { TOOLS } from "../../../config/tools";
import type { ToolId } from "../../../config/tools";
import { NON_DEFAULT_LOCALES } from "../../../i18n/config";
import type { Locale } from "../../../i18n/types";
import { getMessages } from "../../../i18n/utils";

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.flatMap((locale: Locale) =>
    TOOLS.map((tool) => ({
      params: { locale, tool: tool.path },
      props: {
        toolId: tool.id as ToolId,
        locale,
      },
    }))
  );
}

const { toolId, locale } = Astro.props as { toolId: ToolId; locale: Locale };
const messages = getMessages(locale);
const toolCopy = messages.tools[toolId];
---

<BaseLayout
  locale={locale}
  title={`${toolCopy.name} | ${messages.meta.toolTitleSuffix}`}
  description={toolCopy.description}
  activeToolLabel={toolCopy.name}
>
  <ToolWorkspace client:load toolId={toolId} />
</BaseLayout>
