---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolWorkspace from "../../components/ToolWorkspace";
import { TOOLS } from "../../config/tools";
import type { ToolId } from "../../config/tools";
import { getMessages } from "../../i18n/utils";

export function getStaticPaths() {
  return TOOLS.map((tool) => ({
    params: { tool: tool.path },
    props: {
      toolId: tool.id as ToolId,
    },
  }));
}

const { toolId } = Astro.props as { toolId: ToolId };
const messages = getMessages("en");
const toolCopy = messages.tools[toolId];
---

<BaseLayout
  locale="en"
  title={`${toolCopy.name} | ${messages.meta.toolTitleSuffix}`}
  description={toolCopy.description}
  activeToolLabel={toolCopy.name}
>
  <ToolWorkspace client:load toolId={toolId} />
</BaseLayout>
